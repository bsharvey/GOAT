{
  "name": "@goat/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --windows --x64"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.0",
    "@tanstack/react-query": "^5.60.0",
    "recharts": "^2.15.0",
    "framer-motion": "^11.15.0",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/vite": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.goatroyalty.app",
    "productName": "GOAT Royalty App",
    "files": [
      "dist/**/*",
      "electron.js",
      "preload.js"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.music"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
